<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Miawaki Car & Bike Rentals | Premium Fleet 2026</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <nav id="navbar">
        <div class="logo">Miawaki</div>
        <ul class="nav-links">
            <li><a href="#home">Home</a></li>
            <li><a href="#two-wheelers">2-Wheelers</a></li>
            <li><a href="#four-wheelers">4-Wheelers</a></li>
            <li><a href="#usp">USP</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
        <div class="nav-actions">
            <button id="theme-toggle" aria-label="Toggle Dark Mode">🌓</button>
            <div class="burger"><span></span></div>
        </div>
    </nav>

    <header id="home" class="hero">
        <div class="hero-content">
            <h1>Elevate Your Journey.</h1>
            <p>Experience the Indian roads with our exclusive 2026 fleet of hybrid and electric vehicles.</p>
            <a href="#two-wheelers" class="btn">Explore Fleet</a>
        </div>
    </header>

    <!-- 2-WHEELER SECTION -->
    <section id="two-wheelers" class="fleet-section">
        <h2 class="section-title">2-Wheeler Fleet (2026)</h2>
        <div class="fleet-grid">
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="Honda Activa 6G"><h3>Honda Activa 6G (Smart)</h3></div>
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="Suzuki Access 125"><h3>Suzuki Access 125</h3></div>
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="TVS iQube ST"><h3>TVS iQube ST (EV)</h3></div>
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="Ather Rizta"><h3>Ather Rizta</h3></div>
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="Bajaj Chetak"><h3>Bajaj Chetak</h3></div>
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="Yamaha Ray ZR"><h3>Yamaha Ray ZR Hybrid</h3></div>
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="Ola S1 Pro"><h3>Ola S1 Pro Gen 3</h3></div>
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="TVS Ntorq 150"><h3>TVS Ntorq 150</h3></div>
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="Hero Xoom 125"><h3>Hero Xoom 125</h3></div>
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="Aprilia SR 125"><h3>Aprilia SR 125 HPE</h3></div>
        </div>
    </section>

    <!-- 4-WHEELER SECTION -->
    <section id="four-wheelers" class="fleet-section">
        <h2 class="section-title">4-Wheeler Fleet (2026)</h2>
        <div class="fleet-grid">
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="Maruti Dzire"><h3>Maruti Suzuki Dzire (5-Star)</h3></div>
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="Hyundai Verna"><h3>Hyundai Verna Facelift</h3></div>
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="Tata Nexon EV"><h3>Tata Nexon EV</h3></div>
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="Mahindra 7XO"><h3>Mahindra XUV 7XO</h3></div>
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="Honda City Hybrid"><h3>Honda City e:HEV</h3></div>
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="Innova Hycross"><h3>Innova Hycross Hybrid</h3></div>
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="Skoda Slavia"><h3>Skoda Slavia 2026</h3></div>
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="VW Virtus"><h3>VW Virtus Facelift</h3></div>
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="Tata Sierra EV"><h3>Tata Sierra EV</h3></div>
            <div class="fleet-card"><img src="https://via.placeholder.com" alt="Victoris Aura"><h3>Victoris Aura Luxury EV</h3></div>
        </div>
    </section>

    <!-- USP SECTION -->
    <section id="usp">
        <h2 class="section-title">Why Miawaki?</h2>
        <div class="usp-container">
            <div class="usp-item"><h3>Smart Connectivity</h3><p>Real-time weather, traffic, and navigation on every dash.</p></div>
            <div class="usp-item"><h3>Eco-Friendly</h3><p>The largest fleet of Hybrid and EV rentals in the region.</p></div>
            <div class="usp-item"><h3>Safety First</h3><p>All cars hold 5-star safety ratings for your peace of mind.</p></div>
        </div>
    </section>

    <!-- CONTACT FORM -->
    <section id="contact">
        <h2 class="section-title">Inquire Now</h2>
        <form id="contact-form">
            <input type="text" id="name" placeholder="Full Name" required>
            <input type="email" id="email" placeholder="Email Address" required>
            <textarea id="message" rows="5" placeholder="Message/Requirements" required></textarea>
            <button type="submit" class="btn">Send Request</button>
        </form>
    </section>

    <script src="script.js"></script>
</body>
</html>
